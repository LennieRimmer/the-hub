page 20 (
    name: Data Admin
    alias: DATA-ADMIN
    title: Data Admin
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
